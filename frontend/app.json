{
  "expo": {
    "name": "Tonic AI",
    "slug": "tonic-ai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.fz9zg7ri6ry7j973fh4zn",
      "icon": "./assets/images/logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0D1117"
      },
      "package": "app.rork.fz9zg7ri6ry7j973fh4zn"
    },
    "web": {
      "favicon": "./assets/images/logo.png",
      "name": "Tonic AI",
      "shortName": "Tonic AI",
      "description": "AI-powered task manager on TON blockchain"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
